# ─────────────────────────────────────────────────────
# AI Resume Analyzer — Environment Variables
# ─────────────────────────────────────────────────────
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Replace the placeholder below with your real API key
# 3. Never commit your .env file to Git (it's in .gitignore)
#
# Get your free Gemini API key at:
# https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override the Gemini model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Set max resume text length in characters (default: 6000)
# MAX_RESUME_CHARS=6000

# Optional: Set max job description length in characters (default: 3000)
# MAX_JD_CHARS=3000
